{
    "swagger": "2.0",
    "info": {
        "description": "REST API for Real-time Dashboards and Analytics in UCE Trade",
        "title": "MS9 Analytics \u0026 Dashboards API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8000",
    "basePath": "/api/v1/analytics",
    "paths": {
        "/admin": {
            "get": {
                "description": "Fetch KPI and chart data for the admin dashboard based on time period",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "analytics"
                ],
                "summary": "Get Admin Dashboard Stats",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Time period filter (ALL, MONTHLY, WEEKLY)",
                        "name": "period",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/student/{id}": {
            "get": {
                "description": "Fetch KPI and chart data for the student dashboard based on time period",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "analytics"
                ],
                "summary": "Get Student Dashboard Stats",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Student ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Time period filter (ALL, MONTHLY, WEEKLY)",
                        "name": "period",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/student/{id}/report": {
            "get": {
                "description": "Dynamically generate and download a CSV report for the student's sales",
                "produces": [
                    "text/csv"
                ],
                "tags": [
                    "analytics"
                ],
                "summary": "Download Student Report CSV",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Student ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Time period filter",
                        "name": "period",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "CSV file",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}